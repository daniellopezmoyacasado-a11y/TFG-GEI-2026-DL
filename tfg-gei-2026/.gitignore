# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment files, this was removed since the repo offers an example .env and walt.id depends on .env files to work
#this way the installation is simplified
#.env

# Local databases and runtime artifacts
*.db
*.sqlite
*.sqlite3

# OS/editor files
.DS_Store
.idea/
.vscode/

# Local reverse-proxy state
reverse-proxy/data/*
reverse-proxy/config/*
!reverse-proxy/data/.gitkeep
!reverse-proxy/config/.gitkeep
