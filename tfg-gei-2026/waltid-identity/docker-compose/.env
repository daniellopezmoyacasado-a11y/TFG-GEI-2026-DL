VERSION_TAG=stable
# Images for ARM (eg. Apple Silicon) are only available with the `latest` tag

VERSION_OPA=1.4.2
VERSION_VAULT=1.19.3
VERSION_VC_REPO=latest

IMAGE_PREFIX=""
#IMAGE_PREFIX="docker.io/"

SERVICE_HOST=localhost
#SERVICE_HOST=host.docker.internal

WALLET_PUBLIC_URL=https://wallet.localhost
DEMO_WALLET_PUBLIC_URL=https://demo-wallet.localhost
PORTAL_PUBLIC_URL=https://portal.localhost
WALTID_WALLET_API_PUBLIC_URL=https://wallet-api.localhost
WALTID_ISSUER_API_PUBLIC_URL=https://issuer-api.localhost
WALTID_VERIFIER_API_PUBLIC_URL=https://verifier-api.localhost
WALTID_VERIFIER2_API_PUBLIC_URL=https://verifier2-api.localhost
WALTID_VC_REPO_PUBLIC_URL=https://vc-repo.localhost

WALLET_BACKEND_PORT=7001
ISSUER_API_PORT=7002
VERIFIER_API_PORT=7003
VERIFIER_API2_PORT=7004
DEMO_WALLET_FRONTEND_PORT=7101
WEB_PORTAL_PORT=7102
VC_REPO_PORT=7103
DEV_WALLET_FRONTEND_PORT=7104
VAULT_PORT=8200
OPA_SERVER_PORT=8181

#database
DB_NAME=waltid
DB_USERNAME=waltid
DB_PASSWORD=waltid

#sqlite
SQLITE_DB_DATA=data/data.db
#postgres
POSTGRES_DB_PORT=5432
POSTGRES_HOST_PORT=5433
POSTGRES_DB_HOST=postgres # compose service name
POSTGRES_DB_DATA=/waltid-wallet-api/data/
PG_ADMIN_PORT=8080
#mssql
MSSQL_DB_PORT=1433

#sqlite | postgres | mssql
DATABASE_ENGINE=postgres
#identity | identity,tse | identity,opa | services | identity,valkey | all
COMPOSE_PROFILES=identity
